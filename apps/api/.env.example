# Copy to .env and fill in.
DATABASE_URL="postgresql://gibeon:gibeon@localhost:55432/gibeon"
PORT=4000
JWT_SECRET="change-me-in-production"
# Access-token lifetime in seconds (also the auto-logout window). 1800 = 30 min.
JWT_EXPIRES_IN_SECONDS=1800
# Comma-separated allowed origins for CORS (storefront, admin, pos)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"
# Redis (BullMQ) — docker-compose publishes it on 56379
REDIS_HOST=localhost
REDIS_PORT=56379
# Payment provider credentials (leave blank in dev; webhooks verify against these)
PAYSTACK_SECRET=""
FLUTTERWAVE_SECRET=""
FLUTTERWAVE_SECRET_HASH=""
FLUTTERWAVE_CURRENCY="NGN"
# Where hosted checkout returns the shopper (storefront origin, no trailing path)
STOREFRONT_URL="http://localhost:3000"
# Transactional email (Resend). Unset in dev → receipts are logged, not sent.
RESEND_API_KEY=""
MAIL_FROM="Gibeon Empire <orders@gibeonempire.com>"
# Cloudinary — product image uploads (signed direct-to-Cloudinary; secret stays server-side)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="gibeon/products"
